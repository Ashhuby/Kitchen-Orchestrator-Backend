# Database
DB_CONNECTION_STRING=Host=...;Port=5432;Database=postgres;Username=...;Password=...

# JWT
JWT_SIGNING_KEY=your-signing-key-minimum-32-characters
JWT_ISSUER=KitchenOrchestrator.IdentityAPI
